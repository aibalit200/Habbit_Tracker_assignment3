<!DOCTYPE html>
<html>
<head>
    <title>Habit Tracker</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        input, button { margin: 5px; padding: 8px; }
        ul { padding: 0; }
        li { list-style: none; margin: 10px 0; padding: 10px; background: #f0f0f0; border-radius: 5px; }
    </style>
</head>
<body>
    <h1>Habit Tracker</h1>
    
    <form action="/add" method="POST">
        <input type="text" name="name" placeholder="Enter a habit" required>
        <button type="submit">Add Habit</button>
    </form>

    <hr>
    <h2>My Habits</h2>
    <ul>
        {% for habit in habits %}
        <li>
            <form action="/update" method="POST" style="display: inline;">
                <input type="hidden" name="id" value="{{ habit[0] }}">
                <input type="text" name="new_name" value="{{ habit[1] }}" required>
                <button type="submit">Update</button>
            </form>
            <a href="/delete/{{ habit[0] }}" onclick="return confirm('Delete?')">❌ Delete</a>
        </li>
        {% endfor %}
    </ul>

    {% if not habits %}
        <p>No habits yet. Add one above!</p>
    {% endif %}
</body>
</html>
